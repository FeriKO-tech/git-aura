# Optional: raises public GitHub API rate limits for server-side requests.
GITHUB_TOKEN=

# GitHub OAuth App credentials.
# Local callback URL: http://localhost:3000/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Optional: persistent production leaderboard via Upstash Redis REST API.
# Without these, the app falls back to in-memory leaderboard storage.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
